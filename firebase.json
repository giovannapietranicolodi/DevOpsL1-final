{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "Jenkinsfile",
      "README.md",
      "firepit-log.txt",
      "firebase-debug.log",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
